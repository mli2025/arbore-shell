<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="135"
                android:startColor="@color/brand_900"
                android:centerColor="@color/brand_700"
                android:endColor="@color/brand_600"
                android:type="linear" />
        </shape>
    </item>
    <item
        android:width="120dp"
        android:height="120dp"
        android:gravity="center">
        <bitmap
            android:gravity="center"
            android:src="@drawable/logo_splash" />
    </item>
</layer-list>
